{
  "name": "tower",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*"],
  "scripts": {
    "predev": "fuser -k 32354/tcp 32355/tcp 2>/dev/null; true",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "PORT=32355 HOST=0.0.0.0 GIT_AUTO_COMMIT=true WORKSPACE_ROOT=$HOME/workspace DEFAULT_CWD=$HOME/workspace tsx watch --ignore './packages/backend/db/schema.ts' --ignore './packages/backend/db/migrations/*' --ignore './workspace/*' --ignore './docs/*' --ignore './data/*' packages/backend/index.ts",
    "dev:frontend": "vite --host 0.0.0.0 --port 32354",
    "build": "vite build && tsc -p tsconfig.backend.json",
    "start": "pm2 start ecosystem.config.cjs",
    "stop": "pm2 stop tower",
    "restart": "echo '⚠️  개발 중에는 npm run dev 를 사용하세요. restart는 production 전용 (DB 경로가 달라짐)' && npm run build && pm2 restart tower",
    "logs": "pm2 logs tower --lines 50",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.0.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18"
  }
}
