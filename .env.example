# ─────────────────────────────────────────────
# Tower — Environment Variables
# ─────────────────────────────────────────────
# Copy this file:  cp .env.example .env
# Then edit values below.
# ─────────────────────────────────────────────

# ── Server ──
PORT=32354
HOST=0.0.0.0

# ── Workspace ──
# Root directory that users can browse via file tree
WORKSPACE_ROOT=$HOME/workspace
# Default working directory for new Claude sessions
DEFAULT_CWD=$HOME/workspace

# ── Auth ──
# IMPORTANT: Change this to a random secret in production!
JWT_SECRET=change-me-to-a-random-secret
# Set to 'true' to disable authentication (local dev only)
# NO_AUTH=true

# ── Claude ──
# Anthropic API key (alternative to 'claude login')
# Get yours at: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-...
# Permission mode: 'default' | 'acceptEdits' | 'bypassPermissions'
PERMISSION_MODE=bypassPermissions
# Max concurrent Claude sessions
MAX_CONCURRENT_SESSIONS=10
# Path to Claude CLI (auto-detected if not set)
# CLAUDE_PATH=/usr/local/bin/claude

# ── Pi Agent (Multi-Engine) ──
# Enable Pi Agent engine alongside Claude Code
# PI_ENABLED=true
# Default engine for new sessions: 'claude' or 'pi'
# DEFAULT_ENGINE=claude
# OpenRouter API key — required for Pi Agent (pay-per-token models)
# Get yours at: https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-v1-...
# OpenAI API key — optional, for Pi Agent with OpenAI models
# OPENAI_API_KEY=sk-...

# ── Local LLM (OpenAI-compatible API) ──
# Enable local LLM engine (llama.cpp, vLLM, Ollama, etc.)
# LOCAL_LLM_ENABLED=true
# Base URL for the OpenAI-compatible API endpoint
# LOCAL_LLM_BASE_URL=http://localhost:8080
# API key (if required by the server, leave empty if not needed)
# LOCAL_LLM_API_KEY=
# Default model to use (must match a model ID from packages/backend/models.json)
# LOCAL_LLM_DEFAULT_MODEL=local-default

# ── Sandbox (Linux only) ──
# Isolate Claude CLI in a bwrap sandbox (filesystem + PID isolation)
# Requires: apt install bubblewrap
# SANDBOX_ENABLED=true

# ── Database ──
# SQLite database path (relative to project root)
DB_PATH=data/tower.db

# ── Git ──
# Auto-commit Claude's file edits
GIT_AUTO_COMMIT=true

# ── Kakao OAuth ──
# KakaoTalk messaging integration (Settings → KakaoTalk 연결)
# Register app at: https://developers.kakao.com
# KAKAO_REST_KEY=
# KAKAO_CLIENT_SECRET=
# KAKAO_REDIRECT_URI=https://your-domain.example.com/api/auth/kakao/callback

# ── Public URL ──
# Canonical URL used for generating share links.
# Set this to your actual domain so share links always point to the right place.
# Without this, links use window.location.origin (can be wrong if accessed via tunnel/localhost)
# PUBLIC_URL=https://your-domain.example.com
