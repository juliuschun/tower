{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist/backend",
    "rootDir": ".",
    "declaration": true,
    "baseUrl": ".",
    "paths": {
      "@tower/shared": ["packages/shared/index.ts"]
    }
  },
  "include": [
    "packages/backend",
    "packages/shared"
  ],
  "exclude": [
    "packages/backend/**/*.test.ts",
    "packages/backend/scripts/migrate-sqlite-to-pg.ts"
  ]
}
